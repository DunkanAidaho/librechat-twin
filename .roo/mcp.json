{
	"mcpServers": {
		"filesystem": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"~/git"
			],
			"alwaysAllow": [
				"edit_file",
				"get_file_info",
				"read_text_file",
				"read_multiple_files"
			]
		},
		"git": {
			"command": "uvx",
			"args": [
				"mcp-server-git",
				"--repository",
				"~/git"
			]
		}
	}
}